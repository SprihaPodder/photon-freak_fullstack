# CORS Configuration
# Comma-separated list of origins allowed to access the API
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:8000

# Groq API Keys for LLM-powered explanations
# Get your API key from: https://console.groq.com/keys

# Battery Health Explanations
GROQ_API_KEY=your_groq_api_key_here

# Solar Forecasting Explanations
SOLAR_GROQ_API_KEY=your_groq_api_key_here

# Groq Model (optional override)
# Default: llama-3.3-70b-versatile
GROQ_MODEL=llama-3.3-70b-versatile
